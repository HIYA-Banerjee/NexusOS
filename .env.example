# ── NexusOS Environment Variables ───────────────────────────────────────────

# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=NexusOS
APP_URL=http://localhost:3000
WEB_URL=http://localhost:3001

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nexusos:nexusos_dev_pass@localhost:5432/nexusos_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_super_secret_jwt_key_min_64_chars_xxxxxxxxxxxxxxxxxxxxxxxx
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_key_min_64_chars_xxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_EXPIRES_IN=7d

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@nexusos.dev

# ── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── File Storage (MinIO) ──────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=nexusos_minio
MINIO_SECRET_KEY=nexusos_minio_secret
MINIO_BUCKET=nexusos-files
MINIO_USE_SSL=false

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
OPENAI_API_KEY=sk-your-openai-key
OPENAI_API_BASE=https://api.openai.com/v1
AI_DEFAULT_MODEL=gpt-4o-mini

# ── Two-Factor Auth ───────────────────────────────────────────────────────────
TOTP_ISSUER=NexusOS
TOTP_WINDOW=1

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_session_secret_min_32_chars_xxxxxxxxxx

# ── Elasticsearch (Phase 2) ───────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── Crypto / Blockchain Audit (Phase 2) ──────────────────────────────────────
AUDIT_SIGNING_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_APP_NAME=NexusOS
